{
  "proyecto": true,
  "dataset_language": "english",
  "algorithm": "RandomForest",
  "metric_to_evaluate": "macro",
  "hyperparametersKNN": {
    "p_min": 1,
    "p_max": 2,
    "k_min": 1,
    "k_max": 10,
    "w": ["uniform", "distance"],
    "step": 2
  },
  "hyperparametersDecisionTree": {
    "min_depth": 1,
    "max_depth": 40,
    "min_samples_split": 5,
    "min_samples_leaf": 5,
    "criterion":  ["gini", "entropy"]
  },
  "hyperparametersRandomForest": {
    "n_estimators": 200
  },
  "hyperparametersNaiveBayes": {
    "type": "complement",
    "min_alpha": 0.01,
    "max_alpha": 1,
    "step_alpha": 0.01
  },
  "preprocessing": {
    "agrupar_sentimiento_proyecto": false,

    "separator": ",",
    "drop_features": ["reviewId", "gender", "location", "date"],
    "continuous_features_discretize": [],
    "discretize_bins": 10,
    "categorical_features_convert": ["content"],
    "missing_values": "impute",
    "impute_strategy": "mean",
    "scaling": "none",
    "features_scale": ["bill_length_mm", "bill_depth_mm", "flipper_length_mm", "body_mass_g"],

    "text_preprocess": "tf-idf",
    "ngramas_tfidf": 1,
    "balance": "auto",
    "sampling": "none"
  }
}