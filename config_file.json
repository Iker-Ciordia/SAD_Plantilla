{
  "dataset_language": "english",
  "algorithm": "KNN",
  "metric_to_evaluate": "micro",
  "hyperparametersKNN": {
    "p_min": 1,
    "p_max": 2,
    "k_min": 1,
    "k_max": 7,
    "w": ["uniform", "distance"],
    "step": 2
  },
  "hyperparametersDecisionTree": {
    "min_depth": 1,
    "max_depth": 50,
    "min_samples_split": 5,
    "min_samples_leaf": 5,
    "criterion":  ["gini", "entropy"]
  },
  "hyperparametersRandomForest": {
    "n_estimators": 50
  },
  "hyperparametersNaiveBayes": {
    "type": "gaussian",
    "min_alpha": 0.01,
    "max_alpha": 1,
    "step_alpha": 0.01
  },
  "preprocessing": {
    "separator": ",",
    "drop_features": [],
    "continuous_features_discretize": [],
    "discretize_bins": 10,
    "categorical_features_convert": ["gender", "work_type", "Residence_type", "smoking_status", "ever_married"],
    "missing_values": "impute",
    "impute_strategy": "most_frequent",
    "scaling": "standard",
    "features_scale": ["age", "avg_glucose_level", "bmi"],
    "text_preprocess": "one-hot",
    "balance": 0.5,
    "sampling": "none"
  }
}