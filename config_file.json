{
  "dataset_language": "english",
  "algorithm": "NaiveBayes",
  "metric_to_evaluate": "micro",
  "hyperparametersKNN": {
    "p_min": 1,
    "p_max": 2,
    "k_min": 1,
    "k_max": 7,
    "w": ["uniform", "distance"],
    "step": 2
  },
  "hyperparametersDecisionTree": {
    "min_depth": 1,
    "max_depth": 50,
    "min_samples_split": 5,
    "min_samples_leaf": 5,
    "criterion":  ["gini", "entropy"]
  },
  "hyperparametersRandomForest": {
    "n_estimators": 50
  },
  "hyperparametersNaiveBayes": {
    "min_alpha": 0.01,
    "max_alpha": 1,
    "step_alpha": 0.01
  },
  "preprocessing": {
    "separator": ",",
    "drop_features": [],
    "continuous_features_discretize": ["bill_length_mm", "bill_depth_mm", "flipper_length_mm", "body_mass_g"],
    "discretize_bins": 7,
    "categorical_features_convert": ["island", "sex"],
    "missing_values": "impute",
    "impute_strategy": "mean",
    "scaling": "none",
    "features_scale": ["bill_length_mm", "bill_depth_mm", "flipper_length_mm", "body_mass_g"],
    "text_preprocess": "frequency",
    "balance": 0.4,
    "sampling": "None"
  }
}